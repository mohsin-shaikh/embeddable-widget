{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": false,
  "semi": true,
  "printWidth": 100,
  "sortImports": {
    "newlinesBetween": true,
    "internalPattern": ["@/", "~/", "#"],
    "groups": [
      ["builtin", "external"],
      ["internal", "subpath", "parent", "sibling", "index"],
      "style",
      "unknown"
    ]
  },
  "sortTailwindcss": {
    "stylesheet": "./src/main.css"
  },
  "ignorePatterns": ["dist/**", "coverage/**", "package-lock.json"]
}
